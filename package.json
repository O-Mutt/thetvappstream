{
  "name": "thetvappstream",
  "version": "2.0.0",
  "description": "HLS scraper for thetvapp.to — generates M3U playlists and per-channel signed stream URLs.",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "test": "node --test \"tests/*.test.js\"",
    "test:coverage": "node --test --experimental-test-coverage \"tests/*.test.js\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.7",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "entities": "^8.0.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3"
  }
}
